{
  "name": "@phylaxsystems/phylax-rpc",
  "version": "0.0.0",
  "description": "Headless library to detect when a wallet is off the Phylax RPC and help users switch (EIP-6963 detection + credible-require preflight + assisted EIP add/switch/verify).",
  "license": "MIT",
  "author": "Phylax Systems",
  "homepage": "https://github.com/phylaxsystems/phylax-rpc#readme",
  "bugs": "https://github.com/phylaxsystems/phylax-rpc/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phylaxsystems/phylax-rpc.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "examples/wagmi-swap-guard.tsx"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "default": "./dist/advanced.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./wagmi": {
      "types": "./dist/wagmi.d.ts",
      "default": "./dist/wagmi.js"
    },
    "./viem": {
      "types": "./dist/viem.d.ts",
      "default": "./dist/viem.js"
    },
    "./ethers": {
      "types": "./dist/ethers.d.ts",
      "default": "./dist/ethers.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "example": "npm run build && python3 -m http.server 8080",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "lint:package": "publint && attw --pack --profile esm-only",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ethers": ">=6",
    "react": ">=17",
    "viem": ">=2",
    "wagmi": ">=2"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "wagmi": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "ethers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/react": "^18.3.3",
    "@types/react-test-renderer": "^18.3.1",
    "publint": "^0.3.5",
    "react": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^3.2.7"
  },
  "keywords": [
    "phylax",
    "credible-layer",
    "rpc",
    "ethereum",
    "eip-6963",
    "eip-3085",
    "eip-3326",
    "wallet",
    "mev"
  ],
  "engines": {
    "node": ">=22"
  }
}
