{
  "name": "@phylaxsystems/phylax-rpc",
  "version": "0.1.0",
  "description": "Headless library to detect when a wallet is off the Phylax RPC and help users switch (EIP-6963 detection + credible-require preflight + assisted EIP add/switch/verify).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phylaxsystems/phylax-rpc.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./wagmi": {
      "types": "./dist/wagmi.d.ts",
      "import": "./dist/wagmi.js",
      "require": "./dist/wagmi.cjs"
    },
    "./viem": {
      "types": "./dist/viem.d.ts",
      "import": "./dist/viem.js",
      "require": "./dist/viem.cjs"
    },
    "./ethers": {
      "types": "./dist/ethers.d.ts",
      "import": "./dist/ethers.js",
      "require": "./dist/ethers.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "example": "npm run build && python3 -m http.server 8080",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ethers": ">=6",
    "react": ">=17",
    "viem": ">=2",
    "wagmi": ">=2"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "wagmi": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "ethers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "keywords": [
    "phylax",
    "credible-layer",
    "rpc",
    "ethereum",
    "eip-6963",
    "eip-3085",
    "eip-3326",
    "wallet",
    "mev"
  ],
  "engines": {
    "node": ">=18"
  }
}
